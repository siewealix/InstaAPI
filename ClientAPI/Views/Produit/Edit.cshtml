@model ClientAPI.Models.ProduitDTO

@{
    ViewData["Title"] = "Modifier un produit";
}

<div class="container mt-5">
    <h2>Modifier un produit</h2>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="Nom" class="form-label"></label>
            <input asp-for="Nom" class="form-control" />
            <span asp-validation-for="Nom" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Prix" class="form-label"></label>
            <input asp-for="Prix" class="form-control" type="text" />
            <span asp-validation-for="Prix" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" type="number" min="0" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-warning">Enregistrer</button>
        <a asp-action="Index" class="btn btn-secondary">Retour</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
